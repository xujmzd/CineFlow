{
  "name": "CineFlow",
  "version": "1.1.0407",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
  "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
  "dev:renderer": "vite",
  "dev:electron": "wait-on http://localhost:5173 && electron .",
  "build:renderer": "vite build", 
  "build:electron": "electron-builder",
  "build": "npm run build:renderer && npm run build:electron", 
  "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.xujmzd.cineflow",
    "productName": "CineFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false, 
      "allowToChangeInstallationDirectory": true, 
      "createDesktopShortcut": true, 
      "createStartMenuShortcut": true, 
      "shortcutName": "CineFlow", 
      "installerIcon": "electron/assets/icon.ico", 
      "uninstallerIcon": "electron/assets/icon.ico", 
      "installerHeaderIcon": "electron/assets/icon.ico", 
      "uninstallDisplayName": "CineFlow 0.1.0", 
      "license": "LICENSE.txt"
    }
  }
}
